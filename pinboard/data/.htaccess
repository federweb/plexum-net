# Blocca ogni accesso diretto ai file del database e alla chiave segreta.
# pins.json, .secret_key, ratelimit/ non devono mai essere raggiungibili via HTTP.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
